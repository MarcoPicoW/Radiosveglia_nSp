# =============================================================================
#  Radiosveglia_nSp -- Spotify credentials template
# =============================================================================
#
#  Copy this file to spotify.env and fill in your values:
#
#    cp spotify.env.example spotify.env
#    chmod 600 spotify.env
#
#  NEVER commit spotify.env to version control. It is already in .gitignore.
#
#  Alternatively, run tools/setup-spotify.py on your computer: it will
#  generate spotify_token.json which already contains the client credentials,
#  so you only need to copy that file to the Pi.
#
#  Required values:
#    CLIENT_ID      -- from your app at developer.spotify.com
#    CLIENT_SECRET  -- from your app at developer.spotify.com
#    REDIRECT_URI   -- must match the URI registered in your app
# =============================================================================

CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
REDIRECT_URI=http://127.0.0.1:8888/callback
